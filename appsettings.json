{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Backend": {
    "BaseUrl": "",
    "EnrollPath": "/enroll",
    "SendPath": "/send",
    "StatusPath": "/status",
